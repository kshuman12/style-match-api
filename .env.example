# Supabase project URL (e.g. https://abcdefg.supabase.co)
SUPABASE_URL=

# Service role key — bypasses RLS. NEVER commit the real value.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret used by the Next.js frontend on the X-API-Key header.
# Must match the BACKEND_SHARED_SECRET set on the frontend.
SHARED_SECRET=
